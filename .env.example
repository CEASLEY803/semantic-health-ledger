DATABASE_PATH=data/osassistant.sqlite3
WAL_PATH=data/wal.jsonl
GEMINI_API_KEY=

# Your display name — used in LEDGER's system prompts. Never committed to git.
USER_NAME=

# Model routing
# EXTRACTOR_MODEL  — structured JSON extraction (fast, cheap, Flash-class)
# CONVERSATION_MODEL — natural-language replies (reasoning-class, Pro)
# GEMINI_MODEL     — legacy fallback; also used by Mem0 for summarisation
EXTRACTOR_MODEL=gemini-2.5-flash
CONVERSATION_MODEL=gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

OSASSISTANT_API_URL=http://127.0.0.1:8787/api/v1/log/raw
MEM0_USER_ID=primary_user
MEM0_EMBEDDING_MODEL=models/gemini-embedding-001
MEM0_QDRANT_PATH=data/memory/qdrant
MEM0_COLLECTION_NAME=health_ledger_semantic

# Garmin sync (optional — app works without it)
GARMIN_EMAIL=your.garmin@email.com
GARMIN_PASSWORD=your_garmin_password
